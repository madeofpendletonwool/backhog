# Copy to .env and fill in. Only the IGDB credentials are required.

# --- IGDB metadata (required for game search) -------------------------------
# IGDB is authenticated through Twitch. To get credentials:
#   1. Sign in at https://dev.twitch.tv/console/apps
#   2. "Register Your Application" — any name, OAuth Redirect URL
#      http://localhost, Category "Application Integration"
#   3. Copy the Client ID, then "New Secret" for the Client Secret
# Without these the app still runs, but adding new games is disabled.
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=

# --- Optional ---------------------------------------------------------------
# Host port to publish the web UI on.
PORT=8080

# Set to true ONLY if you serve Backhog over HTTPS (e.g. behind Caddy, Traefik,
# or nginx with TLS). On plain HTTP over a LAN address, a Secure cookie is
# silently dropped by the browser and login will appear to do nothing.
COOKIE_SECURE=false
